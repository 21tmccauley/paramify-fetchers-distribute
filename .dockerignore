# Keep the build context lean and avoid leaking local state into the image.
.git
.github
.venv
venv
evidence/
**/__pycache__
**/*.pyc
*.egg-info
.pytest_cache
.mypy_cache
.ruff_cache
*_mock.svg
# Never bake secrets into the image — they're injected at RUNTIME via compose
# env_file. .dockerignore matching is path-anchored (NOT recursive like
# .gitignore), so exclude env files at the root AND in any subdir (e.g. deploy/.env).
.env
.env.*
**/.env
**/.env.*
# Local working manifests (real ones live outside the image).
manifest.yaml
manifests/
